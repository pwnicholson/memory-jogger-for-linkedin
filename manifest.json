{
  "manifest_version": 3,
  "name": "Memory Jogger for LinkedIn",
  "version": "0.3",
  "description": "Add a private 'How I know them' note to LinkedIn profiles. By Paul Nicholson (pwnicholson.com). Not an official LinkedIn app.",
  "permissions": ["storage"],
  "host_permissions": ["https://www.linkedin.com/*"],
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_title": "Memory Jogger for LinkedIn",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "service-worker.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["diagnostics.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content-script.v20260504.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
